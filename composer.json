{
    "name": "sdieunidou/inspecta-ai",
    "description": "Inspecta AI is a PHP CLI tool that applies configurable AI analyses to selected files",
    "type": "application",
    "license": "MIT",
    "authors": [
        {
            "name": "Sébastien Dieunidou",
            "email": "s.dieunidou@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "InspectaAi\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "symfony/console": "^7.3",
        "symfony/options-resolver": "^7.3",
        "symfony/process": "^7.3",
        "symfony/yaml": "^7.3"
    },
    "bin": [
        "inspecta-ai"
    ],
    "config": {
        "prefer-stable": true,
        "sort-packages": true,
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true
        }
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.8",
        "friendsofphp/php-cs-fixer": "^3.90",
        "symfony/var-dumper": "^7.3"
    }
}
